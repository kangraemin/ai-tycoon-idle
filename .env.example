# Android Signing
KEYSTORE_PATH=release.keystore
KEYSTORE_STORE_PASSWORD=your_store_password
KEYSTORE_KEY_ALIAS=aitycoon-key
KEYSTORE_KEY_PASSWORD=your_key_password

# Google Play
GOOGLE_PLAY_KEY_FILE=fastlane/google-play-key.json

# iOS Match (인증서 저장 private repo)
MATCH_GIT_URL=https://github.com/YOUR_USERNAME/match-certs.git
MATCH_PASSWORD=your_match_password

# App Store Connect API Key (비밀번호 대신 API키 권장)
ITC_TEAM_ID=your_itc_team_id
APP_STORE_CONNECT_API_KEY_ID=your_key_id
APP_STORE_CONNECT_API_ISSUER_ID=your_issuer_id
APP_STORE_CONNECT_API_KEY_CONTENT=base64_encoded_p8_content
