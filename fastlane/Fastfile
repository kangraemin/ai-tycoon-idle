default_platform(:android)

# ─── Android ───────────────────────────────────────────────
platform :android do

  desc "Build release AAB (keystore via env vars)"
  lane :build do
    gradle(
      project_dir: "android",
      task: "bundle",
      build_type: "Release",
      properties: {
        "android.injected.signing.store.file"     => ENV["KEYSTORE_PATH"],
        "android.injected.signing.store.password" => ENV["KEYSTORE_STORE_PASSWORD"],
        "android.injected.signing.key.alias"      => ENV["KEYSTORE_KEY_ALIAS"],
        "android.injected.signing.key.password"   => ENV["KEYSTORE_KEY_PASSWORD"],
      }
    )
  end

  desc "Deploy to Google Play (internal track)"
  lane :deploy_internal do
    build
    upload_to_play_store(
      track: "internal",
      aab: "android/app/build/outputs/bundle/release/app-release.aab"
    )
  end

  desc "Deploy to Google Play (production)"
  lane :deploy do
    build
    upload_to_play_store(
      track: "production",
      aab: "android/app/build/outputs/bundle/release/app-release.aab"
    )
  end

end

# ─── iOS ───────────────────────────────────────────────────
platform :ios do

  desc "App Store Connect API Key 로드"
  private_lane :api_key do
    app_store_connect_api_key(
      key_id:                ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id:             ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_content:           ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: true
    )
  end

  desc "Sync certificates & provisioning profiles"
  lane :certs do
    match(type: "appstore", api_key: api_key)
  end

  desc "Build iOS app"
  lane :build do
    match(type: "appstore", readonly: true, api_key: api_key)
    increment_build_number(xcodeproj: "ios/App/App.xcodeproj")
    build_app(
      workspace: "ios/App/App.xcworkspace",
      scheme: "App",
      export_method: "app-store"
    )
  end

  desc "Deploy to App Store (TestFlight)"
  lane :deploy_testflight do
    build
    upload_to_testflight(api_key: api_key)
  end

  desc "Deploy to App Store (production)"
  lane :deploy do
    build
    deliver(force: true, api_key: api_key)
  end

end
